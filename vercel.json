{
  "version": 2,
  "functions": {
    "api/proxy.js": {
      "maxDuration": 30,
      "includeFiles": "bankshakha-page/admin/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/proxy?path=$1"
    },
    {
      "source": "/admin",
      "destination": "/api/proxy?path=admin"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/api/proxy?path=admin/$1"
    },
    {
      "source": "/",
      "destination": "/api/proxy?path="
    }
  ]
}
